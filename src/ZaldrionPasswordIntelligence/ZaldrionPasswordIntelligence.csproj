<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ZaldrionPasswordIntelligence</AssemblyName>
    <RootNamespace>ZaldrionPasswordIntelligence</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>Pedro A. Gonzalez Rodriguez</Authors>
    <Company>Zaldrion</Company>
    <Description>Modern password generator and password intelligence analyzer for Windows.</Description>
    <Copyright>Copyright © 2026 Pedro A. Gonzalez Rodriguez</Copyright>
    <ApplicationIcon>Assets\zaldrion.ico</ApplicationIcon>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
  <Resource Include="Assets\zaldrion.ico" />
</ItemGroup>

</Project>
